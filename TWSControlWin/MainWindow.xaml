<Window x:Class="TWSControlWin.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="TWS Macro/Control"
        Width="420" Height="750"
        ResizeMode="CanMinimize"
        Background="#1a1a2e"
        WindowStartupLocation="CenterScreen">

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="12">
        <StackPanel>

            <TextBlock x:Name="txtTitle" Text="TWS Macro/Control" FontSize="16" FontWeight="Bold"
                       Foreground="#e94560" HorizontalAlignment="Center" Margin="0,4,0,2"/>
            <TextBlock x:Name="txtMac" Text="--:--:--:--:--:--" FontSize="10"
                       Foreground="#8899aa" HorizontalAlignment="Center" Margin="0,0,0,8"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,8">
                <TextBlock Text="L" FontSize="14" FontWeight="Bold" Foreground="#e94560" Margin="0,0,6,0"/>
                <TextBlock x:Name="txtBatteryL" Text="N/A" FontSize="14" FontWeight="Bold" Foreground="#e0e0e0" Margin="0,0,24,0"/>
                <TextBlock Text="R" FontSize="14" FontWeight="Bold" Foreground="#e94560" Margin="0,0,6,0"/>
                <TextBlock x:Name="txtBatteryR" Text="N/A" FontSize="14" FontWeight="Bold" Foreground="#e0e0e0"/>
            </StackPanel>

            <TextBlock x:Name="txtStatus" Text="Disconnected" FontSize="11"
                       Foreground="#8899aa" HorizontalAlignment="Center" Margin="0,0,0,8"/>

            <Button x:Name="btnConnect" Content="CONNECT" Height="36" FontSize="13"
                    Foreground="White" Background="#e94560" BorderThickness="0" Margin="0,0,0,12"
                    Click="BtnConnect_Click"/>

            <!-- ANC -->
            <TextBlock Text="NOISE CANCELLATION" FontSize="10" FontWeight="Bold"
                       Foreground="#90caf9" Margin="0,0,0,6"/>
            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button x:Name="btnAncOn" Grid.Column="0" Content="ANC" Height="36" FontSize="11"
                        Foreground="White" Background="#16213e" BorderThickness="0" Margin="0,0,3,0"
                        Click="BtnAncOn_Click"/>
                <Button x:Name="btnTransparency" Grid.Column="1" Content="Transparency" Height="36" FontSize="11"
                        Foreground="White" Background="#16213e" BorderThickness="0" Margin="3,0,3,0"
                        Click="BtnTransparency_Click"/>
                <Button x:Name="btnAncOff" Grid.Column="2" Content="Normal" Height="36" FontSize="11"
                        Foreground="White" Background="#16213e" BorderThickness="0" Margin="3,0,0,0"
                        Click="BtnAncOff_Click"/>
            </Grid>

            <!-- Game + Touch -->
            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Margin="0,0,4,0">
                    <TextBlock Text="GAME" FontSize="10" FontWeight="Bold" Foreground="#90caf9"
                               HorizontalAlignment="Center" Margin="0,0,0,4"/>
                    <Button x:Name="btnGame" Content="OFF" Height="36" FontSize="13"
                            Foreground="White" Background="#16213e" BorderThickness="0"
                            Click="BtnGame_Click"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Margin="4,0,0,0">
                    <TextBlock Text="TOUCH" FontSize="10" FontWeight="Bold" Foreground="#90caf9"
                               HorizontalAlignment="Center" Margin="0,0,0,4"/>
                    <Button x:Name="btnTouch" Content="OFF" Height="36" FontSize="13"
                            Foreground="White" Background="#16213e" BorderThickness="0"
                            Click="BtnTouch_Click"/>
                </StackPanel>
            </Grid>

            <!-- EQ Presets -->
            <TextBlock Text="EQ PRESETS" FontSize="10" FontWeight="Bold"
                       Foreground="#90caf9" Margin="0,0,0,6"/>
            <Grid x:Name="eqGrid" Margin="0,0,0,4"/>
            <!-- 2x5 grid built in code-behind -->

            <!-- Custom EQ -->
            <Border x:Name="customEqPanel" Background="#222244" Padding="8" Margin="0,4,0,8"
                    Visibility="Collapsed">
                <StackPanel>
                    <TextBlock Text="CUSTOM EQ (dB)" FontSize="10" FontWeight="Bold"
                               Foreground="#90caf9" HorizontalAlignment="Center" Margin="0,0,0,6"/>
                    <StackPanel x:Name="customSliders"/>
                    <Button x:Name="btnCustomSend" Content="Apply Custom EQ" Height="32" FontSize="11"
                            Foreground="White" Background="#e94560" BorderThickness="0" Margin="0,4,0,0"
                            Click="BtnCustomSend_Click"/>
                </StackPanel>
            </Border>

            <!-- Reset -->
            <Button x:Name="btnReset" Content="Reset Device" Height="36" FontSize="12"
                    Foreground="White" Background="#533483" BorderThickness="0" Margin="0,0,0,8"
                    Click="BtnReset_Click"/>

            <TextBlock Text="Made with Free Time and Free Will by FoxLost" FontSize="9"
                       Foreground="#556677" HorizontalAlignment="Right" Margin="0,4,0,0"/>
        </StackPanel>
    </ScrollViewer>
</Window>
